---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="zh-cn">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-[#09090b] text-zinc-200">
		<Header />
		<main class="mx-auto max-w-2xl px-6 py-24 sm:py-32">
			<section class="space-y-8">
				<div class="space-y-4">
					<h1 class="text-4xl font-bold tracking-tight text-zinc-100 sm:text-5xl">
						你好，我是生姜烧肉 👋
					</h1>
					<p class="text-lg leading-8 text-zinc-400">
						这里是我记录学习、思考与成长的技术花园。我热衷于前端开发、Node.js 以及探索更高效的编程方式。
					</p>
				</div>
				
				<div class="flex flex-col gap-4 sm:flex-row sm:items-center">
					<a href={`${base}blog/`} class="inline-flex items-center justify-center rounded-lg bg-zinc-100 px-5 py-2.5 text-sm font-medium text-zinc-900 hover:bg-zinc-200 transition-colors">
						阅读博客
					</a>
					<a href="https://github.com/1421582341" target="_blank" class="inline-flex items-center justify-center rounded-lg border border-zinc-800 px-5 py-2.5 text-sm font-medium text-zinc-100 hover:bg-zinc-900 transition-colors">
						查看 GitHub
					</a>
				</div>

				<div class="grid grid-cols-1 gap-6 pt-12 border-t border-zinc-800">
					<div class="space-y-2">
						<h3 class="text-zinc-100 font-medium">目前的足迹</h3>
						<p class="text-sm text-zinc-500">
							这个站点从 VuePress 彻底进化到了 Astro 6.0，拥有极致的渲染性能。
						</p>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
